# xbl-home local environment template
# Copy this file to `.env` and fill in the real values for local startup.

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=blog
DB_USERNAME=root
DB_PASSWORD=

DEEPSEEK_API_URL=https://api.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner
DEEPSEEK_LANGCHAIN_BASE_URL=
DEEPSEEK_LANGCHAIN_MODEL=
DEEPSEEK_LOG_REQUESTS=false
DEEPSEEK_LOG_RESPONSES=false

WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_DOMAIN=https://www.xbl-blog.top

BLOG_JWT_SECRET=change-this-in-env
BLOG_JWT_EXPIRE_MS=7200000

SERVER_PORT=6101
UPLOAD_IMAGE_PATH=/home/img
UPLOAD_IMAGE_DOMAIN=https://www.xbl-blog.top

MEDICAL_KNOWLEDGE_UPLOAD_DIR=/tmp/xbl-medical/upload
MEDICAL_KNOWLEDGE_ALLOWED_LOCAL_ROOTS=/tmp,/Users/xubaolin
MEDICAL_KNOWLEDGE_CHUNK_SIZE=1600
MEDICAL_KNOWLEDGE_MAX_CHUNK_SIZE=2200
MEDICAL_KNOWLEDGE_AI_TIMEOUT_SECONDS=600
MEDICAL_KNOWLEDGE_PROGRESS_UPDATE_INTERVAL=5
